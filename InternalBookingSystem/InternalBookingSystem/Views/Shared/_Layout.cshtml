<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title> Booker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InternalBookingSystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.5/css/dataTables.dataTables.css" />

    <link rel="icon" href="/Images/PenBookGlassesPhone.jpg" style="border-radius:50px;" type="image/x-icon">

    <!--Toast online styling referencing -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />

    

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg glassBackground ">
            <div class="container-fluid">
                <a class="navbar-brand text-black" asp-area="" asp-controller="Home" asp-action="Index">

                    <img src="~/images/PenBookGlassesPhone.jpg" width="30" height="30" alt="Logo" class="navbar-logo">
                    Booker
                </a>
                <button class="nav-toggle" id="navToggle">
                    ☰
                </button>

                <!--Small device sized nav bar start  (background-color:black;)-->
                <nav class="nav-menu  glassBackground" style=" z-index:100;" id="navMenu" hidden>
                    <ul class="navbar-nav me-auto glassBackground">
                        @if (User.IsInRole(SD.Role_User_NormalUser) || User.IsInRole(SD.Role_User_Manager) || User.IsInRole(SD.Role_User_Admin))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Booking" asp-action="BookingView">Book Equipment</a>
                            </li>

                            @if (User.IsInRole(SD.Role_User_Manager) || User.IsInRole(SD.Role_User_Admin))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Booking" asp-action="ViewResources">View Equipment</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Booking" asp-action="ViewBookings">View Bookings</a>
                            </li>
                        }
                        <li class="nav-item">
                        <partial name="_LoginPartial" style="word-wrap:break-word;" />
                        </li>
                    </ul>

                    
                </nav>
                <!--Small device sized nav bar end-->


                <!--Normal screen size nav bar start-->
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                       
                @if (User.IsInRole(SD.Role_User_NormalUser) || User.IsInRole(SD.Role_User_Manager) || User.IsInRole(SD.Role_User_Admin))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Booking" asp-action="BookingView">Book Equipment</a>
                            </li>

                            @if (User.IsInRole(SD.Role_User_Manager) || User.IsInRole(SD.Role_User_Admin))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Booking" asp-action="ViewResources">View Equipment</a>
                                </li>
                            }
                              <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Booking" asp-action="ViewBookings">View Bookings</a>
                                </li>
                        }       
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
                <!--Normal screen size nav bar end-->

            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - InternalBookingSystem - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <!--Internal jquery start-->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <!--Internal jquery end-->
    
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.datatables.net/2.3.5/js/dataTables.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
